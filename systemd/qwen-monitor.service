#===============================================================================
# systemd service unit for CLIProxyAPI Qwen Monitor
#===============================================================================
# Install:
#   sudo cp qwen-monitor.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable qwen-monitor
#   sudo systemctl start qwen-monitor
#
# Management:
#   sudo systemctl status qwen-monitor
#   sudo systemctl stop qwen-monitor
#   sudo systemctl restart qwen-monitor
#   journalctl -u qwen-monitor -f
#===============================================================================

[Unit]
Description=CLIProxyAPI Qwen Auto-Restart Monitor
Documentation=https://github.com/cativo23/cliproxy-qwen-monitor
After=docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=5

# Run as current user (edit if running as different user)
User=%i
Group=%i

# Working directory (adjust to your CLIProxyAPI installation)
WorkingDirectory=/home/%i/cliproxyapi-dashboard

# Main executable
ExecStart=/home/%i/cliproxy-qwen-monitor/scripts/auto-restart-qwen.sh --config /home/%i/.config/qwen-monitor/config

# Environment
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=DOCKER_CLIENT_TIMEOUT=120

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=qwen-monitor

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=true

# Allow docker access
ReadWritePaths=/tmp /var/run/docker.sock

# Resource limits
MemoryMax=128M
CPUQuota=10%

# Graceful shutdown
TimeoutStopSec=10
KillMode=mixed
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
